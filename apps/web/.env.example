NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Canaux d'assistance affichés aux propriétaires (voir src/lib/support.ts).
# WhatsApp : format international sans "+", ex. 22901020304.
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_SUPPORT_WHATSAPP=
# Centre d'aide Notion : URL publique. Sans valeur, le bouton « Ouvrir le centre
# d'aide » de la modale d'aide n'est pas affiché.
NEXT_PUBLIC_NOTION_HELP_URL=

# Rail FeexPay (ADR-019) — cash-in unique, webhook POST /api/payments/notification
# (signature HMAC-SHA256). SERVEUR UNIQUEMENT, jamais côté client. Activation
# PROD gatée BCEAO : garder FEEXPAY_ENV=sandbox tant que le gate n'est pas levé.
# Client : src/lib/feexpay/.
FEEXPAY_ENV=sandbox
FEEXPAY_API_KEY=
FEEXPAY_SHOP_ID=
FEEXPAY_CALLBACK_URL=
# Secret partagé pour la signature HMAC-SHA256 du webhook FeexPay.
FEEXPAY_WEBHOOK_SECRET=

# Local development only.
# Allows protected app routes to render without an SMS provider.
# Never enable this in production.
RANTI_LOCAL_AUTH=false
RANTI_LOCAL_AUTH_USER_ID=00000000-0000-4000-8000-000000000001
RANTI_LOCAL_AUTH_PHONE=+22900000000
